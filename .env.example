# ============================================================
# Hearthstone Deck Visualizer Bot — пример конфигурации
# Скопируйте этот файл в .env и заполните значения
# ============================================================

# Обязательно: токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=

# Пути к данным карт
IMAGES_PATH=cards
JSON_PATH=cards.json
JSON_RU_PATH=cardsRU.json

# Размер карт в изображении
CARDS_PER_ROW=5
CARD_WIDTH=200
CARD_HEIGHT=300

# WordPress (для публикации колод на сайт)
WP_BASE_URL=https://your-site.com
WP_USER=wordpress_user
WP_APP_PASSWORD=your_app_password
WP_UPLOAD_ENABLED=1

# Telegram-канал для автопубликации (опционально)
# Можно указать username (@channel) или числовой ID (-1001234567890)
CHANNEL_ID=

# ID администраторов бота (через запятую)
ADMIN_IDS=

# API-ключ для приватных endpoints (/render, /meta, /ingest)
# Если не задан — эти endpoints тоже доступны без ключа
API_KEY=

# HSGuru парсер (автоматический постинг колод стримеров)
HSGURU_ENABLED=0
HSGURU_URL=https://www.hsguru.com/streamer-decks
HSGURU_INTERVAL_SECONDS=1800
HSGURU_SEEN_PATH=cache/hsguru_seen.json

# Blizzard Hearthstone API (опционально)
# Получить ключи: https://develop.battle.net/
BLIZZARD_ENABLED=0
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=
BLIZZARD_REGION=eu
BLIZZARD_LOCALE=en_US
BLIZZARD_LOCALE_RU=ru_RU
BLIZZARD_CACHE_DIR=cache/blizzard
BLIZZARD_CACHE_TTL_HOURS=24
BLIZZARD_COLLECTIBLE_ONLY=0
